            addProgram: function(e) {
                e.preventDefault();
                const icon = document.getElementById('new-prog-icon').value.replace('fas ', ''); // Clean prefix if user adds it
                const title = document.getElementById('new-prog-title').value;
                const desc = document.getElementById('new-prog-desc').value;
                
                // Randomize color to keep UI colorful automatically
                const colors = [
                    { color: 'text-nu-green', bg: 'bg-green-100' },
                    { color: 'text-nu-gold', bg: 'bg-yellow-100' },
                    { color: 'text-blue-600', bg: 'bg-blue-100' },
                    { color: 'text-purple-600', bg: 'bg-purple-100' },
                    { color: 'text-red-600', bg: 'bg-red-100' }
                ];
                const theme = colors[Math.floor(Math.random() * colors.length)];

                const newProg = {
                    id: Date.now(),
                    icon: icon,
                    title: title,
                    desc: desc,
                    color: theme.color,
                    bg: theme.bg
                };

                this.db.programs.push(newProg);
                localStorage.setItem('lazisnu_programs', JSON.stringify(this.db.programs));
                document.getElementById('form-add-program').reset();
                
                this.renderAdminPrograms();
                this.renderPrograms(); // Update public site seamlessly
                this.showToast('Program berhasil ditambahkan.');
            },

            deleteProgram: function(id) {
                this.db.programs = this.db.programs.filter(p => p.id !== id);
                localStorage.setItem('lazisnu_programs', JSON.stringify(this.db.programs));
                this.renderAdminPrograms();
                this.renderPrograms();
                this.showToast('Program dihapus dari daftar.');
