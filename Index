            switchAdminTab: function(tabId) {
                document.querySelectorAll('.admin-content-section').forEach(el => el.classList.add('hidden'));
                document.getElementById(`admin-tab-${tabId}`).classList.remove('hidden');
                
                document.querySelectorAll('.admin-tab').forEach(t => {
                    t.classList.remove('bg-green-50', 'border-nu-green', 'text-nu-green-dark');
                    t.classList.add('border-transparent');
                });
                
                const activeTabBtn = document.querySelector(`.admin-tab[data-tab="${tabId}"]`);
                activeTabBtn.classList.remove('border-transparent');
                activeTabBtn.classList.add('bg-green-50', 'border-nu-green', 'text-nu-green-dark');

                // Trigger render for specific dynamic tabs
                if(tabId === 'program-mgr') this.renderAdminPrograms();
                if(tabId === 'banner-mgr') this.renderAdminBanners();
                if(tabId === 'gallery-mgr') this.renderAdminGalleryList();
            },


            // Data Table Rendering & Filtering
            renderAdminTable: function() {
                const tbody = document.getElementById('admin-table-body');
                tbody.innerHTML = '';
                
                const typeFilter = document.getElementById('filter-type').value;
                const catFilter = document.getElementById('filter-category').value;
                
                const now = new Date();
                let filteredData = this.db.donations.filter(d => {
                    const dDate = new Date(d.date);
                    
                    // Time filter
                    let timeMatch = true;
                    if(typeFilter === 'today') {
                        timeMatch = dDate.toDateString() === now.toDateString();
                    } else if (typeFilter === 'month') {
                        timeMatch = dDate.getMonth() === now.getMonth() && dDate.getFullYear() === now.getFullYear();
                    }
                    
                    // Category filter
                    let catMatch = true;
                    if(catFilter !== 'all') {
                        catMatch = d.category === catFilter;
                    }
                    
                    return timeMatch && catMatch;
                });

                // Sort newest first
                filteredData.sort((a,b) => new Date(b.date) - new Date(a.date));

                let total = 0;
                
                if(filteredData.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-gray-500">Belum ada data ditemukan.</td></tr>';
                } else {
                    filteredData.forEach((d, index) => {
                        total += d.amount;
                        const tr = document.createElement('tr');
                        tr.className = 'border-b hover:bg-gray-50';
                        tr.innerHTML = `
                            <td class="px-4 py-3">${formatDateShort(d.date)}</td>
                            <td class="px-4 py-3 font-medium text-gray-900">${d.name}</td>
                            <td class="px-4 py-3"><span class="bg-gray-100 text-xs px-2 py-1 rounded">${d.category}</span></td>
                            <td class="px-4 py-3">${d.method}</td>
                            <td class="px-4 py-3 text-right font-medium">${formatIDR(d.amount)}</td>
                            <td class="px-4 py-3 text-center">
                                <button onclick="app.deleteDonation('${d.id}')" class="text-red-500 hover:text-red-700" title="Hapus"><i class="fas fa-trash"></i></button>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                }
                
                document.getElementById('admin-table-total').textContent = formatIDR(total);
            },

            deleteDonation: function(id) {
                this.db.donations = this.db.donations.filter(d => d.id !== id);
                localStorage.setItem('lazisnu_donations', JSON.stringify(this.db.donations));
                this.renderAdminTable();
                this.showToast('Data berhasil dihapus.');
            },

