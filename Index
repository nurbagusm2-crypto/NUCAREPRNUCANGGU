    <script>
        // Formatter for IDR currency
        const formatIDR = (amount) => {
            return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(amount);
        };

        // Formatter for Date
        const formatDate = (dateStr) => {
            const options = { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
            return new Date(dateStr).toLocaleDateString('id-ID', options);
        };
        const formatDateShort = (dateStr) => {
            return new Date(dateStr).toLocaleDateString('id-ID');
        };

        // Main App Controller - Ready to deploy architecture
        // Note: For GAS Deployment, replace localStorage logic with google.script.run calls.
        const app = {
            // Simulated Database (LocalStorage)
            db: {
                donations: JSON.parse(localStorage.getItem('lazisnu_donations')) || [],
                settings: JSON.parse(localStorage.getItem('lazisnu_settings')) || {
                    logo: 'https://upload.wikimedia.org/wikipedia/commons/e/e0/Logo_NU_%28Nahdlatul_Ulama%29.svg',
                    kopSurat: '', // User can add image URL
                    ketua: 'H. Abdul Ghofur',
                    bendahara: 'M. Sholihin',
                    banks: 'BSI: 7123456789 a.n LAZISNU CANGGU\nBRI: 0123-01-045678-50-1 a.n LAZISNU'
                },
                gallery: JSON.parse(localStorage.getItem('lazisnu_gallery')) || [
                    'https://placehold.co/600x400/006633/FFFFFF?text=Kegiatan+Santunan',
                    'https://placehold.co/600x400/D4AF37/000000?text=Rapat+Pengurus',
                    'https://placehold.co/600x400/004d26/FFFFFF?text=Penyaluran+Zakat',
                    'https://placehold.co/600x400/eeeeee/333333?text=Ambulance+LAZISNU'
                ],
                banners: JSON.parse(localStorage.getItem('lazisnu_banners')) || [
                    'https://placehold.co/1200x500/006633/FFFFFF?text=Selamat+Datang+di+LAZISNU+Canggu',
                    'https://placehold.co/1200x500/D4AF37/000000?text=Salurkan+Zakat+Anda+Bersama+Kami'
                ],
                programs: JSON.parse(localStorage.getItem('lazisnu_programs')) || [
                    { id: 1, icon: 'fa-book-quran', color: 'text-nu-green', bg: 'bg-green-100', title: 'Pendidikan Agama', desc: 'Bantuan operasional TPQ, Madin, dan beasiswa santri di wilayah Canggu.' },
                    { id: 2, icon: 'fa-hand-holding-medical', color: 'text-nu-gold', bg: 'bg-yellow-100', title: 'Sosial & Kesehatan', desc: 'Bantuan pengobatan warga tidak mampu dan santunan anak yatim & dhuafa.' },
                    { id: 3, icon: 'fa-mosque', color: 'text-blue-600', bg: 'bg-blue-100', title: 'Infrastruktur Ibadah', desc: 'Pembangunan dan pemeliharaan fasilitas Masjid dan Musholla setempat.' }
                ]
            },
            
            currentSlide: 0,
            slideInterval: null,
            
            // UI Initialization
            init: function() {
                document.getElementById('current-year').textContent = new Date().getFullYear();
                
                // Setup Mobile Menu Toggle
                document.getElementById('mobile-menu-btn').addEventListener('click', () => {
                    const menu = document.getElementById('mobile-menu');
                    menu.classList.toggle('hidden');
                });

                // Render all dynamic elements
                this.applySettingsToUI();
                this.renderBanners();
                this.renderPrograms();
                this.renderGallery();
                
                // Show home by default
                this.switchView('home');
                
                // Start banner auto-slide safely
                if(this.slideInterval) clearInterval(this.slideInterval);
                this.slideInterval = setInterval(() => this.nextSlide(1), 5000);

                // Initial render of admin tables if they happen to look
                this.renderAdminTable();
            },

            // Navigation
            switchView: function(viewId) {
                // Hide all views
                document.querySelectorAll('.view-section').forEach(el => el.classList.add('hidden'));
                // Show target view
                document.getElementById(`view-${viewId}`).classList.remove('hidden');
                
                // Close mobile menu if open
                document.getElementById('mobile-menu').classList.add('hidden');
                
                window.scrollTo(0, 0);

                // Re-render admin tab active contents if entering dashboard
                if(viewId === 'admin-dashboard') {
                    this.renderAdminTable();
                    this.renderAdminPrograms();
                    this.renderAdminBanners();
                    this.renderAdminGalleryList();
                }
            },
            
            scrollTo: function(elementId) {
                this.switchView('home');
                setTimeout(() => {
                    document.getElementById(elementId).scrollIntoView({ behavior: 'smooth' });
                }, 100);
            },

            // Custom Toast Notification
            showToast: function(message, type = 'success') {
                const container = document.getElementById('toast-container');
                const toast = document.createElement('div');
                
                const bgColor = type === 'success' ? 'bg-green-50 border-green-500 text-green-800' : 'bg-red-50 border-red-500 text-red-800';
                const icon = type === 'success' ? 'fa-check-circle text-green-500' : 'fa-exclamation-circle text-red-500';

                toast.className = `flex items-center w-full max-w-xs p-4 space-x-3 bg-white border-l-4 rounded-lg shadow ${bgColor} toast-enter`;
                toast.innerHTML = `
                    <i class="fas ${icon} text-xl"></i>
                    <div class="text-sm font-medium">${message}</div>
                `;
                
                container.appendChild(toast);
                
                // Trigger animation
                setTimeout(() => { toast.classList.remove('toast-enter'); toast.classList.add('toast-enter-active'); }, 10);
                
                // Remove after 3s
                setTimeout(() => {
                    toast.classList.replace('toast-enter-active', 'toast-exit');
                    setTimeout(() => toast.classList.add('toast-exit-active'), 10);
                    setTimeout(() => toast.remove(), 300);
                }, 3000);
            },


            // Banner Logic
            renderBanners: function() {
                const container = document.getElementById('slider-container');
                container.innerHTML = '';
                
                if (this.db.banners.length === 0) {
                    container.innerHTML = `<div class="absolute inset-0 w-full h-full bg-nu-green flex items-center justify-center text-white"><p>Belum ada banner</p></div>`;
                    return;
                }

                this.db.banners.forEach((url, index) => {
                    const div = document.createElement('div');
                    div.className = `absolute inset-0 w-full h-full transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`;
                    div.id = `slide-${index}`;
                    div.innerHTML = `
                        <div class="absolute inset-0 bg-black/40 z-10"></div>
                        <img src="${url}" class="w-full h-full object-cover z-0" alt="Banner" onerror="this.src='https://placehold.co/1200x500/cccccc/ffffff?text=Image+Error'">
                    `;
                    container.appendChild(div);
                });
                this.currentSlide = 0;
            },
            
            nextSlide: function(direction) {
                const slides = document.querySelectorAll('#slider-container > div');
                if(slides.length <= 1) return;
                
                slides[this.currentSlide].classList.remove('opacity-100');
                slides[this.currentSlide].classList.add('opacity-0');
                
                this.currentSlide = (this.currentSlide + direction + slides.length) % slides.length;
                
                slides[this.currentSlide].classList.remove('opacity-0');
                slides[this.currentSlide].classList.add('opacity-100');
            },

            // Programs Logic
            renderPrograms: function() {
                const grid = document.getElementById('programs-grid');
                grid.innerHTML = '';
                this.db.programs.forEach(p => {
                    grid.innerHTML += `
                        <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition text-center border border-gray-100">
                            <div class="w-16 h-16 ${p.bg} ${p.color} rounded-full flex items-center justify-center text-2xl mx-auto mb-4">
                                <i class="fas ${p.icon}"></i>
                            </div>
                            <h3 class="text-xl font-bold mb-2">${p.title}</h3>
                            <p class="text-gray-600 text-sm">${p.desc}</p>
                        </div>
                    `;
                });
            },

            // Gallery Logic
            renderGallery: function() {
                const grid = document.getElementById('gallery-grid');
                grid.innerHTML = '';
                this.db.gallery.forEach(url => {
                    grid.innerHTML += `
                        <div class="aspect-w-1 aspect-h-1 rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition group">
                            <img src="${url}" alt="Galeri" class="w-full h-full object-cover group-hover:scale-110 transition duration-500" onerror="this.src='https://placehold.co/600x400/cccccc/ffffff?text=Error'">
                        </div>
                    `;
                });
            },


            // Form Logic
            handleCategoryChange: function() {
                const category = document.getElementById('don-category').value;
                const ahliKuburContainer = document.getElementById('ahli-kubur-container');
                const ahliKuburInput = document.getElementById('don-ahli-kubur');
                
                if (category === 'Infaq Rutin Jamiyah' || category === 'Donatur Tetap') {
                    ahliKuburContainer.classList.remove('hidden');
                    ahliKuburInput.required = true;
                } else {
                    ahliKuburContainer.classList.add('hidden');
                    ahliKuburInput.required = false;
                    ahliKuburInput.value = '';
                }
            },

            handlePaymentChange: function() {
                const method = document.querySelector('input[name="payment-method"]:checked').value;
                const instruction = document.getElementById('payment-instruction');
                instruction.classList.remove('hidden');
                
                if (method === 'Jemput Donasi') {
                    instruction.innerHTML = '<i class="fas fa-info-circle text-blue-500 mr-2"></i> Petugas Amil kami akan menghubungi Anda untuk mengatur waktu penjemputan donasi ke alamat yang tertera.';
                } else if (method === 'Transfer Bank') {
                    const banks = this.db.settings.banks.replace(/\n/g, '<br>');
                    instruction.innerHTML = `<p class="font-semibold mb-1">Silakan transfer ke salah satu rekening berikut:</p><div class="text-gray-700 bg-white p-2 rounded border border-gray-200 mt-2">${banks}</div>`;
                } else if (method === 'QRIS') {
                    instruction.innerHTML = `
                        <p class="font-semibold mb-2">Scan QRIS berikut menggunakan aplikasi e-Wallet atau M-Banking:</p>
                        <div class="bg-white p-2 rounded border border-gray-200 inline-block">
                            <img src="https://placehold.co/200x200/ffffff/000000?text=QRIS+Dummy" alt="QRIS LAZISNU" class="w-32 h-32 object-contain mx-auto">
                        </div>
                    `;
                }
            },

            submitDonation: function(e) {
                e.preventDefault();
                
                const btn = document.getElementById('btn-submit-donasi');
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Memproses...';
                btn.disabled = true;

                // Gather data
                const nama = document.getElementById('don-name').value || 'Hamba Allah';
                const phone = document.getElementById('don-phone').value;
                const address = document.getElementById('don-address').value;
                const category = document.getElementById('don-category').value;
                const ahliKubur = document.getElementById('don-ahli-kubur').value;
                const amount = parseInt(document.getElementById('don-amount').value);
                const method = document.querySelector('input[name="payment-method"]:checked').value;
                const txId = 'TRX-' + Date.now().toString().slice(-6);
                const dateIso = new Date().toISOString();

                const donationData = {
                    id: txId,
                    date: dateIso,
                    name: nama,
                    phone: phone,
                    address: address,
                    category: category,
                    ahliKubur: ahliKubur,
                    amount: amount,
                    method: method
                };

                // Save to simulated DB
                this.db.donations.push(donationData);
                localStorage.setItem('lazisnu_donations', JSON.stringify(this.db.donations));

                // Simulate network delay
                setTimeout(() => {
                    this.showToast('Data donasi berhasil dicatat!');
                    this.generateReceipt(donationData);
                    document.getElementById('donation-form').reset();
                    document.getElementById('ahli-kubur-container').classList.add('hidden');
                    document.getElementById('payment-instruction').classList.add('hidden');
                    
                    btn.innerHTML = '<span>Konfirmasi & Lanjutkan</span><i class="fas fa-paper-plane ml-2"></i>';
                    btn.disabled = false;
                }, 800);
            },

            generateReceipt: function(data) {
                // Populate Receipt View
                document.getElementById('rec-id').textContent = data.id;
                document.getElementById('rec-date').textContent = formatDate(data.date);
                document.getElementById('rec-name').textContent = data.name;
                document.getElementById('rec-category').textContent = data.category;
                document.getElementById('rec-method').textContent = data.method;
                document.getElementById('rec-amount').textContent = formatIDR(data.amount);
                document.getElementById('rec-sign-name').textContent = data.name;
                
                const ahliRow = document.getElementById('rec-ahli-kubur-row');
                if(data.ahliKubur) {
                    ahliRow.classList.remove('hidden');
                    ahliRow.classList.add('flex');
                    document.getElementById('rec-ahli-kubur').textContent = data.ahliKubur;
                } else {
                    ahliRow.classList.add('hidden');
                    ahliRow.classList.remove('flex');
                }

                this.switchView('receipt');
            },

            downloadReceiptJPG: function() {
                const element = document.getElementById('receipt-card');
                
                // visual tweak before capture
                element.style.borderRadius = '0'; 
                
                html2canvas(element, {
                    scale: 2, // Higher resolution
                    useCORS: true,
                    backgroundColor: '#ffffff'
                }).then(canvas => {
                    // Restore visual
                    element.style.borderRadius = ''; 
                    
                    const link = document.createElement('a');
                    link.download = `Bukti_Donasi_${document.getElementById('rec-id').textContent}.jpg`;
                    link.href = canvas.toDataURL('image/jpeg', 0.9);
                    link.click();
                    this.showToast('Bukti JPG berhasil diunduh.');
                }).catch(err => {
                    console.error(err);
                    this.showToast('Gagal menghasilkan gambar.', 'error');
                });
