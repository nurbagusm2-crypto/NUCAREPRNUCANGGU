<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Informasi Manajemen LAZISNU PRNU Canggu</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'nu-green': '#006633',
                        'nu-green-dark': '#004d26',
                        'nu-gold': '#D4AF37',
                        'nu-gold-light': '#F3E5AB'
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- html2canvas -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }

        /* Hide elements during printing */
        @media print {
            body { background-color: white; }
            .no-print { display: none !important; }
            .print-only { display: block !important; }
            
            /* Print settings for A4 */
            @page {
                size: A4 portrait;
                margin: 20mm;
            }
            
            #print-area {
                width: 100%;
                margin: 0;
                padding: 0;
            }
        }

        .print-only { display: none; }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #006633; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #004d26; }

        /* Slider Animations */
        .fade {
            animation-name: fade;
            animation-duration: 1.5s;
        }
        @keyframes fade {
            from {opacity: .4} 
            to {opacity: 1}
        }

        /* Toast Animation */
        .toast-enter { transform: translateY(100%); opacity: 0; }
        .toast-enter-active { transform: translateY(0); opacity: 1; transition: all 300ms ease-in-out; }
        .toast-exit { transform: translateY(0); opacity: 1; }
        .toast-exit-active { transform: translateY(100%); opacity: 0; transition: all 300ms ease-in-out; }
    </style>
</head>
<body class="text-gray-800 antialiased flex flex-col min-h-screen">

    <!-- Custom Message Box (Replaces Alert) -->
    <div id="toast-container" class="fixed bottom-4 right-4 z-50 flex flex-col gap-2 no-print"></div>

    <!-- Navbar -->
    <nav class="bg-white shadow-md sticky top-0 z-40 no-print">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-20">
                <div class="flex items-center cursor-pointer" onclick="app.switchView('home')">
                    <img id="nav-logo" src="https://upload.wikimedia.org/wikipedia/commons/e/e0/Logo_NU_%28Nahdlatul_Ulama%29.svg" alt="Logo LAZISNU" class="app-logo h-12 w-auto object-contain mr-3">
                    <div>
                        <h1 class="text-xl font-bold text-nu-green leading-tight">LAZISNU PRNU</h1>
                        <p class="text-xs text-gray-500 font-medium">Canggu, Jetis, Mojokerto</p>
                    </div>
                </div>
                
                <!-- Desktop Menu -->
                <div class="hidden md:flex items-center space-x-8">
                    <button onclick="app.switchView('home')" class="text-gray-600 hover:text-nu-green font-medium transition">Beranda</button>
                    <button onclick="app.scrollTo('gallery')" class="text-gray-600 hover:text-nu-green font-medium transition">Galeri</button>
                    <button onclick="app.switchView('donate')" class="bg-nu-green text-white px-6 py-2 rounded-full font-semibold hover:bg-nu-green-dark transition shadow-lg shadow-nu-green/30">
                        <i class="fas fa-hand-holding-heart mr-2"></i> Donasi Sekarang
                    </button>
                    <button onclick="app.switchView('admin-login')" class="text-gray-400 hover:text-nu-gold transition" title="Login Admin">
                        <i class="fas fa-user-shield"></i>
                    </button>
                </div>

                <!-- Mobile Menu Button -->
                <div class="md:hidden flex items-center">
                    <button id="mobile-menu-btn" class="text-gray-600 hover:text-nu-green focus:outline-none">
                        <i class="fas fa-bars text-2xl"></i>
                    </button>
                </div>
            </div>
        </div>
        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden bg-white border-t">
            <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
                <button onclick="app.switchView('home')" class="block w-full text-left px-3 py-2 text-gray-700 hover:text-nu-green hover:bg-green-50 rounded-md">Beranda</button>
                <button onclick="app.switchView('donate')" class="block w-full text-left px-3 py-2 text-nu-green font-bold hover:bg-green-50 rounded-md">Donasi</button>
                <button onclick="app.switchView('admin-login')" class="block w-full text-left px-3 py-2 text-gray-500 hover:text-nu-gold rounded-md">Admin Dashboard</button>
            </div>
        </div>
    </nav>

    <main class="flex-grow w-full">
        
        <!-- ==================== VIEW: HOME ==================== -->
        <div id="view-home" class="view-section">
            
            <!-- Banner Slider -->
            <div class="relative w-full h-[300px] sm:h-[400px] md:h-[500px] bg-gray-900 overflow-hidden group">
                <div id="slider-container" class="w-full h-full relative">
                    <!-- Slides injected by JS -->
                </div>
                <!-- Slider Controls -->
                <button onclick="app.nextSlide(-1)" class="absolute top-1/2 left-4 -translate-y-1/2 bg-white/30 hover:bg-white/50 text-white rounded-full w-10 h-10 flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                    <i class="fas fa-chevron-left"></i>
                </button>
                <button onclick="app.nextSlide(1)" class="absolute top-1/2 right-4 -translate-y-1/2 bg-white/30 hover:bg-white/50 text-white rounded-full w-10 h-10 flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                    <i class="fas fa-chevron-right"></i>
                </button>
            </div>

            <!-- Program Features -->
            <div class="max-w-7xl mx-auto px-4 py-16">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-bold text-gray-800">Program Penyaluran</h2>
                    <div class="w-24 h-1 bg-nu-gold mx-auto mt-4 rounded"></div>
                </div>
                <div id="programs-grid" class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <!-- Programs injected by JS -->
                </div>
            </div>

            <!-- Gallery Section -->
            <div id="gallery" class="bg-white py-16">
                <div class="max-w-7xl mx-auto px-4">
                    <div class="text-center mb-12">
                        <h2 class="text-3xl font-bold text-gray-800">Galeri Kegiatan</h2>
                        <div class="w-24 h-1 bg-nu-green mx-auto mt-4 rounded"></div>
                    </div>
                    <div id="gallery-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                        <!-- Gallery items injected by JS -->
                    </div>
                </div>
            </div>
            
            <!-- Call to Action -->
            <div class="bg-nu-green py-16 relative overflow-hidden">
                <div class="absolute inset-0 opacity-10" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
                <div class="max-w-4xl mx-auto px-4 text-center relative z-10">
                    <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Mari Berinvestasi untuk Akhirat</h2>
                    <p class="text-green-100 text-lg mb-8">Salurkan Zakat, Infaq, dan Shodaqoh Anda melalui LAZISNU PRNU Canggu. Transparan, Amanah, dan Tepat Sasaran.</p>
                    <button onclick="app.switchView('donate')" class="bg-nu-gold hover:bg-yellow-500 text-gray-900 px-8 py-4 rounded-full font-bold text-lg transition shadow-xl transform hover:-translate-y-1">
                        Formulir Donasi Online <i class="fas fa-arrow-right ml-2"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- ==================== VIEW: DONATION FORM ==================== -->
        <div id="view-donate" class="view-section hidden max-w-3xl mx-auto px-4 py-12">
            <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
                <div class="bg-nu-green p-6 text-center text-white relative">
                    <div class="absolute inset-0 opacity-20" style="background-image: url('data:image/svg+xml,%3Csvg width=\'20\' height=\'20\' viewBox=\'0 0 20 20\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\' fill-rule=\'evenodd\'%3E%3Ccircle cx=\'3\' cy=\'3\' r=\'3\'/%3E%3Ccircle cx=\'13\' cy=\'13\' r=\'3\'/%3E%3C/g%3E%3C/svg%3E');"></div>
                    <h2 class="text-2xl font-bold relative z-10">Formulir Donasi Online</h2>
                    <p class="text-green-100 mt-2 relative z-10">Isi data di bawah ini untuk memulai donasi</p>
                </div>
                
                <form id="donation-form" class="p-6 md:p-8 space-y-6" onsubmit="app.submitDonation(event)">
                    <!-- Data Diri -->
                    <div class="space-y-4">
                        <h3 class="text-lg font-semibold text-gray-800 border-b pb-2"><i class="fas fa-user text-nu-green mr-2"></i>Data Donatur</h3>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Nama Lengkap (Hamba Allah jika kosong)</label>
                            <input type="text" id="don-name" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-nu-green focus:border-nu-green outline-none transition" placeholder="Contoh: Budi Santoso">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">No. WhatsApp</label>
                            <input type="tel" id="don-phone" required class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-nu-green focus:border-nu-green outline-none transition" placeholder="08123456789">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Alamat Lengkap</label>
                            <textarea id="don-address" rows="2" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-nu-green focus:border-nu-green outline-none transition" placeholder="RT/RW, Dusun, Desa"></textarea>
                        </div>
                    </div>
                  <div class="mb-4">
                    <label for="donasi-tanggal" class="block text-sm font-medium text-gray-700">Tanggal Donasi<label>
                    <input type="date" id="donasi-tanggal" name="tanggal" 
                           class="w-full mt-1 p-2 border rounded-lg focus:ring-2 focus:ring-green-500"  
                           required>
                    </div>
                    <!-- Kategori & Nominal -->
                    <div class="space-y-4 pt-4">
                        <h3 class="text-lg font-semibold text-gray-800 border-b pb-2"><i class="fas fa-hand-holding-dollar text-nu-green mr-2"></i>Rincian Donasi</h3>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Kategori Donasi</label>
                            <select id="don-category" required onchange="app.handleCategoryChange()" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-nu-green focus:border-nu-green outline-none transition bg-white">
                                <option value="" disabled selected>Pilih Kategori...</option>
                                <option value="Zakat Fitrah">Zakat Fitrah</option>
                                <option value="Zakat Maal">Zakat Maal</option>
                                <option value="Infaq Umum">Infaq Umum</option>
                                <option value="Shodaqoh">Shodaqoh</option>
                                <option value="Infaq Rutin Jamiyah">Infaq Rutin Jamiyah</option>
                                <option value="Donatur Tetap">Donatur Tetap</option>
                            </select>
                        </div>

                        <!-- Data Ahli Kubur (Hidden by default) -->
                        <div id="ahli-kubur-container" class="hidden bg-green-50 p-4 rounded-xl border border-green-200">
                            <label class="block text-sm font-medium text-nu-green-dark mb-1">
                                <i class="fas fa-users-praying mr-1"></i> Data Ahli Kubur (Khusus Infaq Rutin/Donatur Tetap)
                            </label>
                            <p class="text-xs text-gray-500 mb-2">Pisahkan dengan koma jika lebih dari satu (Maks. 5 nama disarankan)</p>
                            <textarea id="don-ahli-kubur" rows="3" class="w-full px-4 py-3 rounded-xl border border-green-300 focus:ring-2 focus:ring-nu-green outline-none transition" placeholder="Contoh: Fulan bin Fulan, Fulanah binti Fulan"></textarea>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Nominal (Rp)</label>
                            <input type="number" id="don-amount" required min="1000" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-nu-green focus:border-nu-green outline-none transition" placeholder="Contoh: 50000">
                        </div>
                    </div>

                    <!-- Metode Pembayaran -->
                    <div class="space-y-4 pt-4">
                        <h3 class="text-lg font-semibold text-gray-800 border-b pb-2"><i class="fas fa-wallet text-nu-green mr-2"></i>Metode Pembayaran</h3>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            <label class="cursor-pointer">
                                <input type="radio" name="payment-method" value="Jemput Donasi" class="peer sr-only" required onchange="app.handlePaymentChange()">
                                <div class="rounded-xl border-2 border-gray-200 p-4 text-center peer-checked:border-nu-green peer-checked:bg-green-50 transition">
                                    <i class="fas fa-motorcycle text-2xl mb-2 text-gray-600 peer-checked:text-nu-green"></i>
                                    <div class="font-semibold text-sm">Jemput Donasi</div>
                                </div>
                            </label>
                            <label class="cursor-pointer">
                                <input type="radio" name="payment-method" value="Transfer Bank" class="peer sr-only" onchange="app.handlePaymentChange()">
                                <div class="rounded-xl border-2 border-gray-200 p-4 text-center peer-checked:border-nu-green peer-checked:bg-green-50 transition">
                                    <i class="fas fa-building-columns text-2xl mb-2 text-gray-600 peer-checked:text-nu-green"></i>
                                    <div class="font-semibold text-sm">Transfer Bank</div>
                                </div>
                            </label>
                            <label class="cursor-pointer">
                                <input type="radio" name="payment-method" value="QRIS" class="peer sr-only" onchange="app.handlePaymentChange()">
                                <div class="rounded-xl border-2 border-gray-200 p-4 text-center peer-checked:border-nu-green peer-checked:bg-green-50 transition">
                                    <i class="fas fa-qrcode text-2xl mb-2 text-gray-600 peer-checked:text-nu-green"></i>
                                    <div class="font-semibold text-sm">QRIS</div>
                                </div>
                            </label>
                        </div>

                        <!-- Payment Instructions -->
                        <div id="payment-instruction" class="hidden bg-gray-50 p-4 rounded-xl border border-gray-200 text-sm">
                            <!-- Injected by JS -->
                        </div>
                    </div>

                    <div class="pt-6">
                        <button type="submit" id="btn-submit-donasi" class="w-full bg-nu-green hover:bg-nu-green-dark text-white font-bold py-4 rounded-xl shadow-lg transition flex justify-center items-center">
                            <span>Konfirmasi & Lanjutkan</span>
                            <i class="fas fa-paper-plane ml-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- ==================== VIEW: RECEIPT ==================== -->
        <div id="view-receipt" class="view-section hidden max-w-2xl mx-auto px-4 py-12">
            
            <div class="mb-6 flex justify-between items-center no-print">
                <button onclick="app.switchView('home')" class="text-gray-500 hover:text-nu-green"><i class="fas fa-arrow-left mr-2"></i>Kembali</button>
                <div class="space-x-2">
                    <button onclick="app.downloadReceiptJPG()" class="bg-gray-800 hover:bg-black text-white px-4 py-2 rounded-lg text-sm font-medium transition">
                        <i class="fas fa-image mr-1"></i> Unduh JPG
                    </button>
                    <button onclick="window.print()" class="bg-nu-gold hover:bg-yellow-500 text-gray-900 px-4 py-2 rounded-lg text-sm font-medium transition">
                        <i class="fas fa-print mr-1"></i> Cetak PDF
                    </button>
                </div>
            </div>

            <!-- Receipt Card (Target for html2canvas) -->
            <div id="receipt-card" class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-200 print-area-receipt relative">
                <!-- Watermark -->
                <div class="absolute inset-0 flex items-center justify-center opacity-5 pointer-events-none z-0">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/e/e0/Logo_NU_%28Nahdlatul_Ulama%29.svg" class="w-64 h-64 object-contain">
                </div>

                <div class="bg-nu-green p-6 text-white text-center relative z-10 flex flex-col items-center">
                    <img id="receipt-logo" src="https://upload.wikimedia.org/wikipedia/commons/e/e0/Logo_NU_%28Nahdlatul_Ulama%29.svg" alt="Logo" class="app-logo h-16 w-auto object-contain bg-white rounded-full p-2 mb-3">
                    <h2 class="text-xl font-bold">TANDA TERIMA DONASI</h2>
                    <p class="text-sm text-green-100">LAZISNU PRNU CANGGU MOJOKERTO</p>
                </div>
                
                <div class="p-8 relative z-10">
                    <div class="flex justify-between items-center border-b pb-4 mb-4">
                        <div>
                            <p class="text-xs text-gray-500 uppercase tracking-wider">Tanggal</p>
                            <p class="font-semibold text-gray-800" id="rec-date">-</p>
                        </div>
                        <div class="text-right">
                            <p class="text-xs text-gray-500 uppercase tracking-wider">ID Transaksi</p>
                            <p class="font-mono font-semibold text-gray-800" id="rec-id">-</p>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Nama Donatur</span>
                            <span class="font-bold text-gray-800 text-right" id="rec-name">-</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Kategori</span>
                            <span class="font-semibold text-gray-800 bg-green-100 text-nu-green px-3 py-1 rounded-full text-sm" id="rec-category">-</span>
                        </div>
                        <div id="rec-ahli-kubur-row" class="hidden flex-col bg-gray-50 p-3 rounded-lg border border-gray-100">
                            <span class="text-gray-500 text-xs mb-1">Data Ahli Kubur</span>
                            <span class="font-medium text-gray-800 italic" id="rec-ahli-kubur">-</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Metode Penyerahan</span>
                            <span class="font-medium text-gray-800" id="rec-method">-</span>
                        </div>
                    </div>

                    <div class="mt-8 bg-gray-50 p-4 rounded-xl border border-dashed border-gray-300 flex justify-between items-center">
                        <span class="text-gray-600 font-medium">Nominal Donasi</span>
                        <span class="text-2xl font-bold text-nu-green" id="rec-amount">-</span>
                    </div>

                    <div class="mt-8 text-center">
                        <p class="text-sm text-gray-500 italic">"Semoga Allah memberikan pahala atas apa yang engkau berikan, dan menjadikannya pembersih bagimu."</p>
                        <div class="mt-6 flex justify-between px-8">
                            <div class="text-center">
                                <p class="text-xs text-gray-500 mb-8">Penerima (Amil)</p>
                                <p class="font-semibold text-sm border-t border-gray-300 pt-1">Admin LAZISNU</p>
                            </div>
                            <div class="text-center">
                                <p class="text-xs text-gray-500 mb-8">Donatur</p>
                                <p class="font-semibold text-sm border-t border-gray-300 pt-1" id="rec-sign-name">Hamba Allah</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-100 p-3 text-center text-xs text-gray-400">
                    Dokumen ini sah dicetak otomatis oleh sistem.
                </div>
            </div>
            
            <!-- Instructions post-donation -->
            <div class="mt-6 bg-blue-50 border-l-4 border-blue-500 p-4 rounded shadow-sm no-print">
                <div class="flex">
                    <div class="flex-shrink-0"><i class="fas fa-info-circle text-blue-500"></i></div>
                    <div class="ml-3">
                        <p class="text-sm text-blue-700">
                            Jika Anda memilih metode <b>Transfer</b> atau <b>QRIS</b>, mohon segera selesaikan pembayaran sesuai nominal di atas. Simpan struk ini sebagai bukti.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- ==================== VIEW: ADMIN LOGIN ==================== -->
        <div id="view-admin-login" class="view-section hidden max-w-md mx-auto px-4 py-20">
            <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 text-center">
                <div class="w-16 h-16 bg-green-100 text-nu-green rounded-full flex items-center justify-center text-2xl mx-auto mb-4">
                    <i class="fas fa-lock"></i>
                </div>
                <h2 class="text-2xl font-bold mb-6">Login Administrator</h2>
                <form onsubmit="app.loginAdmin(event)" class="space-y-4">
                    <input type="password" id="admin-pin" placeholder="Masukkan PIN (1234)" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-nu-green outline-none text-center tracking-widest text-lg" required>
                    <button type="submit" class="w-full bg-nu-green hover:bg-nu-green-dark text-white font-bold py-3 rounded-xl transition">
                        Masuk Dashboard
                    </button>
                </form>
                <p class="text-xs text-gray-400 mt-4">Untuk demo, gunakan PIN: 1234</p>
            </div>
        </div>

        <!-- ==================== VIEW: ADMIN DASHBOARD ==================== -->
        <div id="view-admin-dashboard" class="view-section hidden w-full bg-gray-50 min-h-screen pb-12">
            <!-- Admin Topbar -->
            <div class="bg-nu-green-dark text-white p-4 shadow-md no-print">
                <div class="max-w-7xl mx-auto flex justify-between items-center">
                    <h2 class="font-bold text-lg"><i class="fas fa-shield-alt mr-2"></i> Panel Admin LAZISNU</h2>
                    <button onclick="app.logoutAdmin()" class="text-sm bg-red-600 hover:bg-red-700 px-3 py-1 rounded transition">Logout</button>
                </div>
            </div>

            <div class="max-w-7xl mx-auto px-4 mt-6 grid grid-cols-1 md:grid-cols-4 gap-6 no-print">
