                    list.innerHTML += `
                        <div class="bg-gray-50 p-4 rounded-lg border flex justify-between items-center">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 ${p.bg} ${p.color} rounded-full flex items-center justify-center text-xl">
                                    <i class="fas ${p.icon}"></i>
                                </div>
                                <div>
                                    <h4 class="font-bold text-gray-800">${p.title}</h4>
                                    <p class="text-xs text-gray-500">${p.desc}</p>
