            // Print Report PDF Logic
            preparePrintReport: function() {
                // Populate Print Area
                const s = this.db.settings;
                const kopImg = document.getElementById('print-kop-surat');
                const kopFallback = document.getElementById('print-kop-fallback');
                
                if(s.kopSurat && s.kopSurat.trim() !== '') {
                    kopImg.src = s.kopSurat;
                    kopImg.style.display = 'block';
                    kopFallback.classList.add('hidden');
                } else {
                    kopImg.style.display = 'none';
                    kopFallback.classList.remove('hidden');
                }

                document.getElementById('print-sign-ketua').textContent = s.ketua || '....................';
                document.getElementById('print-sign-bendahara').textContent = s.bendahara || '....................';
                
                const nowStr = new Date().toLocaleDateString('id-ID', {day:'numeric', month:'long', year:'numeric'});
                document.getElementById('print-date-now').textContent = nowStr;

                // Sync table data with active filter
                const typeFilter = document.getElementById('filter-type').options[document.getElementById('filter-type').selectedIndex].text;
                document.getElementById('print-report-period').textContent = 'Periode: ' + typeFilter;

                const printTbody = document.getElementById('print-table-body');
                
                // Copy rows, but remove the action column
                printTbody.innerHTML = '';
                let printTotal = 0;
                let counter = 1;
                
                // We re-calculate based on current table state to ensure consistency
                const tableRows = document.querySelectorAll('#admin-table-body tr');
                
                if(tableRows.length > 0 && tableRows[0].cells.length > 1) { // check if not empty message
                    tableRows.forEach(tr => {
                        const date = tr.cells[0].textContent;
                        const name = tr.cells[1].textContent;
                        const cat = tr.cells[2].textContent;
                        const amountStr = tr.cells[4].textContent;
                        
                        const val = parseInt(amountStr.replace(/[^0-9]/g, ''));
                        if(!isNaN(val)) printTotal += val;

                        const newRow = document.createElement('tr');
                        newRow.innerHTML = `
                            <td class="border border-gray-800 px-2 py-1 text-center">${counter++}</td>
                            <td class="border border-gray-800 px-2 py-1">${date}</td>
                            <td class="border border-gray-800 px-2 py-1">${name}</td>
                            <td class="border border-gray-800 px-2 py-1">${cat}</td>
                            <td class="border border-gray-800 px-2 py-1 text-right">${amountStr}</td>
                        `;
                        printTbody.appendChild(newRow);
                    });
                } else {
                     printTbody.innerHTML = '<tr><td colspan="5" class="border border-gray-800 px-2 py-1 text-center">Nihil</td></tr>';
                }

                document.getElementById('print-table-total').textContent = formatIDR(printTotal);

                // Show only print area by using window.print() 
                // The CSS @media print handles hiding the rest of the UI
                setTimeout(() => {
                    window.print();
                }, 500);
            }
        };

        // Initialize App on DOM Load
        window.addEventListener('DOMContentLoaded', () => {
            app.init();
        });
